# ============================================
# BACKEND ENVIRONMENT VARIABLES
# ============================================

# AWS Bedrock (Required for AI features)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1

# Database Configuration
# Using Supabase Transaction Pooler (IPv4 compatible)
# Ensure password special characters are URL-encoded (e.g., @ -> %40)
DATABASE_URL="postgresql://postgres.fmuiclyhbwodxldaeltu:bewell%40hackathon@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres"

# JWT Authentication
JWT_SECRET=your-super-secret-key-change-in-production

# Snowflake ID Generator (Unique Worker ID for distributed systems)
WORKER_ID=1

# Environment (development/production)
ENVIRONMENT=development

# CORS Allowed Origins (comma-separated for production)
ALLOWED_ORIGINS=http://localhost:3000,https://your-vercel-app.vercel.app

# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================

# Backend API URL (used by Next.js frontend)
# Development: http://localhost:8000
# Production: https://your-backend-url.railway.app or https://your-backend-url.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================
# DEPLOYMENT NOTES
# ============================================
# 
# For Vercel (Frontend):
# - Only NEXT_PUBLIC_* variables are exposed to the browser
# - Set NEXT_PUBLIC_API_URL in Vercel dashboard
#
# For Railway/Render (Backend):
# - Set all backend variables in Railway/Render dashboard
# - DATABASE_URL is usually auto-provided by the platform
# - Update ALLOWED_ORIGINS with your Vercel domain
#
